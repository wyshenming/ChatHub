{
  "name": "chathub",
  "version": "1.2.7",
  "description": "ChatHub",
  "productName": "ChatHub",
  "author": "染泓如梦QAQ",
  "main": "src/main.js",
  "scripts": {
    "icon:generate": "node scripts/generate-icon-ico.mjs",
    "start": "electron .",
    "dist": "npm run icon:generate && electron-builder --win --x64 --dir && node scripts/set-exe-metadata.js --unpacked-only && node scripts/copy-x64-app-exe.js && electron-builder --win nsis --x64 --prepackaged dist/win-unpacked",
    "dist:dir": "npm run icon:generate && electron-builder --win --x64 --dir && node scripts/set-exe-metadata.js --unpacked-only && node scripts/copy-x64-app-exe.js"
  },
  "build": {
    "appId": "local.chathub",
    "productName": "ChatHub",
    "extraMetadata": {
      "name": "chathub",
      "productName": "ChatHub",
      "description": "ChatHub",
      "author": "染泓如梦QAQ"
    },
    "directories": {
      "output": "dist"
    },
    "artifactName": "${productName}-Setup-${arch}.${ext}",
    "files": [
      "build/icon.ico",
      "build/icon.png",
      "src/**/*",
      "package.json"
    ],
    "win": {
      "icon": "build/icon.ico",
      "executableName": "ChatHub",
      "signAndEditExecutable": false,
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "include": "build/installer.nsh"
    }
  },
  "devDependencies": {
    "electron": "^43.2.0",
    "electron-builder": "^26.15.3",
    "png-to-ico": "^3.0.1",
    "rcedit": "^5.0.2"
  }
}
